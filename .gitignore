# --- Credentials & user-state (NEVER commit) ---
.env
*.env
state/oauth_tokens.json
state/xapi_endpoint_shape.json
state/kol_snapshot_*.json

# --- User's personal KOL list (template ships as kol_list.example.md) ---
kol_list.md

# --- Runtime queue contents (drafts, posted, rejected — personal data) ---
queue/pending/*
queue/posted/*
queue/rejected/*
!queue/pending/.gitkeep
!queue/posted/.gitkeep
!queue/rejected/.gitkeep

# --- Python ---
.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Editor / OS ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~
.gstack/
