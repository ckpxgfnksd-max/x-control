# Copy to ~/.config/x-control/.env (chmod 600) and fill in.

# xapi.to — KOL reads only (your account is NEVER sent here)
XAPI_API_KEY=

# Official X API — OAuth 2.0 Confidential client from developer.x.com
# Callback URI must be: http://127.0.0.1:8765/callback
# Scopes required: tweet.read, tweet.write, users.read, offline.access
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=

# Cost guardrail (USD). Aborts the run if exceeded mid-pulse.
MAX_DAILY_API_SPEND_USD=2.00

# Optional: override xapi.to base URL if you have a different endpoint
# XAPI_BASE_URL=https://api.xapi.to
